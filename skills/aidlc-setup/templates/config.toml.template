# AI-DLC プロジェクト設定
# 生成日: [現在日時]

starter_kit_version = "[version.txt の内容]"

[project]
name = "[プロジェクト名]"
description = "[プロジェクト概要]"
type = "[プロジェクトタイプ]"
# starter_kit_repo: スターターキットのリポジトリパス（フォーク時に変更）
# - デフォルト: "ghq:github.com/ikeisuke/ai-dlc-starter-kit"
# - ghq形式のパス（例: "ghq:github.com/your-org/your-fork"）
# starter_kit_repo = "ghq:github.com/ikeisuke/ai-dlc-starter-kit"

[project.tech_stack]
languages = [[言語リスト]]
frameworks = [[フレームワークリスト]]
tools = ["Claude Code"]

[rules]
# 開発ルール

[rules.coding]
naming_convention = "[命名規則]"
# 追加のコーディングルールはここに記載

[rules.security]
validate_user_input = true
use_env_for_secrets = true

[rules.git]
# Git運用ルール（v2.1.8で統合）
commit_on_unit_complete = true
commit_on_phase_complete = true
# branch_mode: "branch" | "worktree" | "ask"
# - branch: 常にブランチ方式で自動作成
# - worktree: 常にworktree方式で自動作成
# - ask: ユーザーに都度質問（デフォルト）
branch_mode = "ask"
# unit_branch_enabled: Unit単位でブランチを作成するか
unit_branch_enabled = false

[rules.documentation]
language = "日本語"

[rules.reviewing]
# exclude_patterns: レビュー対象から除外するファイルパターン（配列）
# - デフォルトパターン(.env*, *.key, *.pem, credentials.*, *secret*)は常に適用
# - ここに追加のパターンを指定可能
# exclude_patterns = ["*.p12", "config/secrets/**"]

[rules.feedback]
# フィードバック送信機能設定（v1.13.3で追加）
# enabled: true | false
# - true: フィードバック送信機能を有効化（デフォルト）
# - false: フィードバック送信機能を無効化（企業利用時のセキュリティ対策）
enabled = true

[rules.custom]
# プロジェクト固有のカスタムルール
# 必要に応じて追記してください

[inception]
# Inception Phase設定
