{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bin/check-utf8-corruption.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bin/*)",
      "Bash(chmod +x:*)",
      "Bash(claude:*)",
      "Bash(dasel:*)",
      "Bash(echo:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(jq:*)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git pull:*)",
      "Bash(git revert:*)",
      "Bash(markdownlint:*)",
      "Bash(mktemp /tmp/aidlc-:*)",
      "Bash(npx markdownlint-cli:*)",
      "Bash(skills/aidlc/scripts/*)",
      "Bash(test:*)",
      "Skill(aidlc-setup)",
      "Skill(codex-review)",
      "Skill(reviewing-architecture)",
      "Skill(reviewing-code)",
      "Skill(reviewing-inception)",
      "Skill(reviewing-security)",
      "Skill(squash-unit)",
      "Bash(cat:*)",
      "Bash(command -v:*)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(skills/*/bin/*)",
      "Bash(GIT_TERMINAL_PROMPT=0 git fetch:*)",
      "Bash(gh auth status)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit -F:*)",
      "Bash(git commit -m:*)",
      "Bash(git commit:*)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git merge-base *)",
      "Bash(git push *)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git rev-parse *)",
      "Bash(git show:*)",
      "Bash(git status *)",
      "Bash(git tag *)",
      "Bash(grep:*)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(skills/*/scripts/*)",
      "Bash(tee -a .aidlc/cycles/*/history/*)",
      "Skill(aidlc-feedback)",
      "Skill(aidlc-migrate)",
      "Skill(reviewing-inception-intent)",
      "Skill(reviewing-inception-stories)",
      "Skill(reviewing-inception-units)",
      "Skill(reviewing-construction-plan)",
      "Skill(reviewing-construction-design)",
      "Skill(reviewing-construction-code)",
      "Skill(reviewing-construction-integration)",
      "Skill(reviewing-operations-deploy)",
      "Skill(reviewing-operations-premerge)",
      "Skill(write-history)"
    ],
    "ask": [
      "Bash(git push*--force *)",
      "Bash(git push*--force-with-lease *)",
      "Bash(git branch*-D *)",
      "Bash(git branch*--force *)",
      "Bash(git tag*-d *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout . *)",
      "Bash(gh pr merge *)"
    ]
  }
}
